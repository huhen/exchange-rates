{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=exchangerates;Username=postgres;Password=postgres;Include Error Detail=true",
    "Redis": "localhost:6379"
  },
  "Caching": {
    "DefaultEntryOptions": {
      "Expiration": "00:30:00",
      "LocalCacheExpiration": "00:01:00",
      "CacheProfiles": {
        "GetPasswordHashQuery": {
          "Expiration": "00:01:00",
          "LocalCacheExpiration": "00:00:30"
        }
      }
    }
  },
  "JwtToken": {
    "CertificatePath": "ecdsa-cert-demo.pfx",
    "CertificatePassword": "demo-key",
    "ExpirationInMinutes": 5,
    "Audience": "internal-services",
    "Issuer": "http://identity-service",
    "OpenIdConfigurationUri": "http://localhost:5268/.well-known/openid-configuration",
    "JwksUri": "http://localhost:5268/.well-known/jwks"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "Microsoft.AspNetCore.Mvc.Infrastructure": "Warning",
        "System.Net.Http.HttpClient.OtlpMetricExporter": "Warning",
        "System.Net.Http.HttpClient.OtlpTraceExporter": "Warning"
      }
    }
  }
}
